# Data layer mode: "local" (LocalStorage mock) or "supabase" (real database)
VITE_DATA_MODE=local

# Required only when VITE_DATA_MODE=supabase
# (copy these from Supabase -> Project Settings -> API, or the framework
# quickstart; the "publishable" key is the new name for the anon/public key)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxx
# Legacy projects can use the old variable instead:
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
